{
  "$schema": "../../node_modules/ng-packagr/ng-package.schema.json",
  "dest": "../../dist/gob-ds",
  "lib": {
    "entryFile": "src/public-api.ts"
  },
  "assets": [
    "./src/styles.scss",
    {
      "input": "./src/tokens/styles",
      "glob": "**/*.scss",
      "output": "./tokens/styles"
    },
    {
      "input": "./src/assets",
      "glob": "**/*",
      "output": "./assets"
    }
  ]
}